APP_NAME=library-api
ENVIRONMENT=local
LOG_LEVEL=INFO
DATABASE_URL=postgresql+asyncpg://library:library@db:5432/library
TEST_DATABASE_URL=postgresql+asyncpg://library:library@localhost:5433/library_test
POSTGRES_USER=library
POSTGRES_PASSWORD=library
POSTGRES_DB=library
JWT_SECRET_KEY=change-me-use-a-long-random-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
MAX_CSV_UPLOAD_BYTES=1048576
CORS_ORIGINS=
RATE_LIMIT_ENABLED=false
REDIS_URL=redis://redis:6379/0
